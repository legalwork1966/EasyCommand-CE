<Window x:Class="EasyCommand.ApiKeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="API Key Required"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="18">
        <Grid Width="560">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Enter your OpenAI API key" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource SubtleTextBrush}"
                           TextWrapping="Wrap"
                           Text="This is stored as a per-user environment variable (OPENAI_API_KEY) so it is not saved in your project files or committed to GitHub."/>
            </StackPanel>

            <Border Grid.Row="1" Margin="0,14,0,0" Background="#F6F7F9" CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock Text="API Key" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="KeyBox" Margin="0,8,0,0" Padding="10,8" FontFamily="Consolas" FontSize="13"/>
                    <DockPanel Margin="0,10,0,0">
                        <CheckBox x:Name="ShowKeyChk" Content="Show key" VerticalAlignment="Center" Checked="ShowKeyChk_Checked" Unchecked="ShowKeyChk_Unchecked"/>
                        <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" Text=" You can change this later in Windows Environment Variables."/>
                    </DockPanel>

                    <!-- Visible textbox only when ShowKeyChk is enabled -->
                    <TextBox x:Name="KeyTextBox" Margin="0,8,0,0" Padding="10,8" FontFamily="Consolas" FontSize="13" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2" Margin="0,12,0,0" Foreground="{StaticResource SubtleTextBrush}" TextWrapping="Wrap">
                Tip: If your key starts with &quot;sk-&quot;, paste it as-is.
            </TextBlock>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Cancel" Width="100" Click="CancelBtn_Click"/>
                <Button Content="Save" Width="100" Margin="10,0,0,0" Style="{StaticResource PrimaryButton}" IsDefault="True" Click="SaveBtn_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
