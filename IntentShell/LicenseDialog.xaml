<Window x:Class="EasyCommand.LicenseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License Agreement"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        Width="720" Height="520"
        MinWidth="520" MinHeight="420">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="End User License Agreement" />
            <TextBlock Margin="0,6,0,0" Opacity="0.75"
                       TextWrapping="Wrap"
                       Text="Please review the license terms below. You must accept to use this software." />
        </StackPanel>

        <Border Grid.Row="1" BorderThickness="1" CornerRadius="6" Padding="8">
            <Border.BorderBrush>
                <SolidColorBrush Color="#33000000"/>
            </Border.BorderBrush>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="EulaText"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         BorderThickness="0"
                         Background="Transparent"
                         FontFamily="Consolas"
                         FontSize="12"
                         AcceptsReturn="True"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="AgreeCheck"
                      VerticalAlignment="Center"
                      Content="I have read and agree to the terms"
                      Checked="AgreeCheck_Checked"
                      Unchecked="AgreeCheck_Checked"/>

            <Button Grid.Column="1"
                    Margin="12,0,0,0"
                    MinWidth="110"
                    IsCancel="True"
                    Content="Decline"
                    Click="Decline_Click"/>

            <Button x:Name="AcceptBtn"
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    MinWidth="110"
                    IsDefault="True"
                    Content="I Agree"
                    IsEnabled="False"
                    Click="Accept_Click"/>
        </Grid>
    </Grid>
</Window>