<Window x:Class="EasyCommand.ResponsibilityDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Responsibility Notice"
        Height="300" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource AppBgBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock TextWrapping="Wrap" FontSize="14" Foreground="{StaticResource TextBrush}">
            <Run FontWeight="Bold">Important Notice:</Run><LineBreak/><LineBreak/>
            You are solely responsible for reviewing and approving all commands generated by this application before execution.<LineBreak/><LineBreak/>
            This software is provided "AS IS", without warranty of any kind, express or implied. The authors are not liable for any damages or data loss resulting from the use of this software.
        </TextBlock>

        <CheckBox x:Name="AcceptCheckBox" 
                  Grid.Row="1" 
                  Margin="0,20,0,20"
                  Content="I understand and accept full responsibility for commands executed."
                  Checked="AcceptCheckBox_CheckedChanged"
                  Unchecked="AcceptCheckBox_CheckedChanged"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ExitButton" 
                    Content="Exit" 
                    Width="100" 
                    Click="ExitButton_Click"
                    Margin="0,0,10,0"/>
            <Button x:Name="ContinueButton" 
                    Content="Continue" 
                    Width="100" 
                    IsEnabled="False"
                    Click="ContinueButton_Click"
                    Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>