<Window x:Class="EasyCommand.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Easy Command"
        Height="720" Width="1100"
        MinHeight="580" MinWidth="880"
        Background="{StaticResource AppBgBrush}"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="RunButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Background"   Value="#0E7A3C"/>
                    <Setter Property="Foreground"   Value="White"/>
                    <Setter Property="BorderBrush"  Value="#0B6331"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background"   Value="#E0E0E0"/>
                    <Setter Property="Foreground"   Value="#9E9E9E"/>
                    <Setter Property="BorderBrush"  Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"  Value="#C0392B"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#A93226"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ── Menu ── -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Save Script"      InputGestureText="Ctrl+S" Click="SaveBtn_Click"/>
                <MenuItem Header="Save Script _As…"                            Click="SaveAsBtn_Click"/>
                <Separator/>
                <MenuItem Header="Set API Key…"                                Click="SetApiKey_Click"/>
                <MenuItem Header="Clear API Key…"                              Click="ClearApiKey_Click"/>
                <Separator/>
                <MenuItem Header="E_xit"             InputGestureText="Alt+F4" Click="ExitBtn_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Keyboard Shortcuts" InputGestureText="F1"   Click="ShortcutsBtn_Click"/>
                <Separator/>
                <MenuItem Header="About"                                       Click="AboutBtn_Click"/>
            </MenuItem>
        </Menu>

        <!-- ── Status bar ── -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="White"
                   BorderThickness="0,1,0,0"
                   BorderBrush="{StaticResource BorderBrush}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar x:Name="BusyBar"
                                 Width="110" Height="10"
                                 IsIndeterminate="True"
                                 Visibility="Collapsed"
                                 Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText"
                               Text="Ready"
                               Foreground="{StaticResource SubtleTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ExitCodeLabel"
                               Text="Exit code: "
                               Foreground="{StaticResource SubtleTextBrush}"
                               Visibility="Collapsed"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ExitCodeText"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Visibility="Collapsed"
                               VerticalAlignment="Center"
                               Margin="0,0,14,0"/>
                    <TextBlock x:Name="ShellModeLabel"
                               Foreground="{StaticResource SubtleTextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Main content ── -->
        <Grid Margin="14,10,14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Easy Command"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Describe what you want to do. Review the drafted command, then run it."
                               Foreground="{StaticResource SubtleTextBrush}"
                               FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Shell:" VerticalAlignment="Center"
                               Margin="0,0,6,0" Foreground="{StaticResource SubtleTextBrush}"/>
                    <RadioButton x:Name="PowerShellRdo"
                                 Content="PowerShell"
                                 IsChecked="True"
                                 VerticalAlignment="Center"
                                 Margin="0,0,12,0"
                                 Checked="ShellMode_Changed"
                                 ToolTip="Use PowerShell — saves as .ps1"/>
                    <RadioButton x:Name="CmdRdo"
                                 Content="CMD"
                                 VerticalAlignment="Center"
                                 Margin="0,0,16,0"
                                 Checked="ShellMode_Changed"
                                 ToolTip="Use Windows Command Prompt — saves as .bat"/>
                    <Button x:Name="ClearBtn"
                            Content="🗑  Clear"
                            Width="90"
                            ToolTip="Clear all panels  (Ctrl+L)"
                            Click="ClearBtn_Click"/>
                </StackPanel>
            </Grid>

            <!-- Prompt card -->
            <Border Grid.Row="1"
                    Margin="0,10,0,10"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="YOUR REQUEST"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Margin="0,0,0,4"/>

                    <ScrollViewer Grid.Row="1"
                                  MaxHeight="140"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBox x:Name="PromptInput"
                                 MinHeight="72"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 FontFamily="Segoe UI"
                                 FontSize="13"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 PreviewKeyDown="PromptInput_PreviewKeyDown"
                                 ToolTip="Ctrl+Enter → Draft   F5 → Run"/>
                    </ScrollViewer>

                    <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="DraftBtn"
                                Content="⚡ Draft"
                                Width="110"
                                Style="{StaticResource PrimaryButton}"
                                ToolTip="Generate command (Ctrl+Enter)"
                                IsEnabled="False"
                                Click="DraftBtn_Click"/>
                        <Button x:Name="RunBtn"
                                Content="▶  Run"
                                Width="110"
                                Margin="8,0,0,0"
                                Style="{StaticResource RunButtonStyle}"
                                ToolTip="Execute command (F5)"
                                IsEnabled="False"
                                Click="RunBtn_Click"/>
                        <Button x:Name="CancelBtn"
                                Content="✖  Cancel"
                                Width="110"
                                Margin="8,0,0,0"
                                Style="{StaticResource CancelButtonStyle}"
                                ToolTip="Cancel current operation"
                                Visibility="Collapsed"
                                Click="CancelBtn_Click"/>
                        <Separator Width="1" Margin="10,2"/>
                        <Button x:Name="CopyPromptBtn"
                                Content="Copy Prompt"
                                Width="110"
                                ToolTip="Copy prompt text to clipboard"
                                Click="CopyPromptBtn_Click"/>
                        <Button x:Name="PasteExampleBtn"
                                Content="Paste Example"
                                Width="118"
                                Margin="8,0,0,0"
                                ToolTip="Insert a sample prompt"
                                Click="PasteExampleBtn_Click"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- Script + Output panels -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Script panel -->
                <Border Background="White"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Plan + Script" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Border x:Name="ScriptBadge"
                                        Background="#EBF5FB" BorderBrush="#AED6F1"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="5,1" Margin="8,0,0,0"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="ScriptBadgeText" FontSize="10" Foreground="#2471A3"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Copy" Width="72"
                                        ToolTip="Copy script to clipboard"
                                        Click="CopyScriptBtn_Click"/>
                                <Button Content="Save" Width="72" Margin="6,0,0,0"
                                        ToolTip="Save script to file (Ctrl+S)"
                                        Click="SaveBtn_Click"/>
                            </StackPanel>
                        </Grid>
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBox x:Name="PlanBox"
                                     FontFamily="Consolas" FontSize="13"
                                     AcceptsReturn="True" AcceptsTab="True"
                                     TextWrapping="NoWrap"
                                     BorderThickness="0" Background="Transparent"
                                     TextChanged="PlanBox_TextChanged"
                                     ToolTip="You may edit this command before running"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Resizable splitter -->
                <GridSplitter Grid.Column="1"
                              Width="4"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeWE"
                              ShowsPreview="True"/>

                <!-- Output panel -->
                <Border Grid.Column="2"
                        Background="White"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Execution Output" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Border x:Name="OutputBadge"
                                        CornerRadius="4" Padding="5,1"
                                        Margin="8,0,0,0" Visibility="Collapsed">
                                    <TextBlock x:Name="OutputBadgeText" FontSize="10"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Copy" Width="72"
                                        ToolTip="Copy output to clipboard"
                                        Click="CopyOutputBtn_Click"/>
                                <Button Content="Clear" Width="72" Margin="6,0,0,0"
                                        ToolTip="Clear execution output"
                                        Click="ClearOutputBtn_Click"/>
                            </StackPanel>
                        </Grid>
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBox x:Name="OutputBox"
                                     FontFamily="Consolas" FontSize="13"
                                     AcceptsReturn="True" IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     BorderThickness="0" Background="Transparent"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>