<Window x:Class="IntentShell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Easy Command"
        Height="680" Width="1040"
        MinHeight="560" MinWidth="860" Background="Gainsboro"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Save Script" InputGestureText="Ctrl+S" Click="SaveBtn_Click"/>
                <MenuItem Header="Save Script _As..." Click="SaveAsBtn_Click"/>
                <Separator/>
                <MenuItem Header="Set API Key..." Click="SetApiKey_Click"/>
                <MenuItem Header="Clear API Key..." Click="ClearApiKey_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="ExitBtn_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About" Click="AboutBtn_Click"/>
                <Separator/>
                <MenuItem Header="Keyboard Shortcuts" Click="ShortcutsBtn_Click"/>
            </MenuItem>
        </Menu>

        <!-- Status -->
        <StatusBar DockPanel.Dock="Bottom" Background="#FFFFFF" BorderThickness="1,0,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar x:Name="BusyBar" Width="110" Height="10" IsIndeterminate="True" Visibility="Collapsed" Margin="0,0,10,0"/>
                    <TextBlock x:Name="StatusText" Text="Ready" Foreground="{StaticResource SubtleTextBrush}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Content -->
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Ask" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Describe what you want to do. Draft a safe command, then run after approval."
                               Foreground="{StaticResource SubtleTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="PowerShellChk" Content="Use PowerShell" IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0" Checked="PowerShellChk_Changed" Unchecked="PowerShellChk_Changed"/>
                    <Button x:Name="ClearBtn" Content="Clear" Width="96" Click="ClearBtn_Click"/>
                </StackPanel>
            </Grid>

            <!-- Prompt + actions -->
            <Border Grid.Row="1" Margin="0,14,0,14" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="PromptInput"
                             MinHeight="84"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             FontFamily="Consolas"
                             FontSize="14"
                             PreviewKeyDown="PromptInput_PreviewKeyDown"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="DraftBtn" Content="Draft" Width="110" Style="{StaticResource PrimaryButton}" Click="DraftBtn_Click" IsEnabled="False"/>
                        <Button x:Name="RunBtn" Content="Run" Width="110" Margin="10,0,0,0" IsEnabled="False" Click="RunBtn_Click" />
                        <Separator Margin="12,0" Width="1"/>
                        <Button x:Name="CopyPromptBtn" Content="Copy Prompt" Width="120" Click="CopyPromptBtn_Click"/>
                        <Button x:Name="PasteExampleBtn" Content="Paste Example" Width="130" Margin="10,0,0,0" Click="PasteExampleBtn_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Script + output -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Plan + Script" FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Copy" Width="80" Click="CopyScriptBtn_Click"/>
                                <Button Content="Save" Width="80" Margin="10,0,0,0" Click="SaveBtn_Click"/>
                            </StackPanel>
                        </Grid>

                        <TextBox x:Name="PlanBox" Grid.Row="1"
                                 FontFamily="Consolas"
                                 AcceptsReturn="True"
                                 TextChanged="PlanBox_TextChanged"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Execution Output" FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Copy" Width="80" Click="CopyOutputBtn_Click"/>
                                <Button Content="Clear" Width="80" Margin="10,0,0,0" Click="ClearOutputBtn_Click"/>
                            </StackPanel>
                        </Grid>

                        <TextBox x:Name="OutputBox" Grid.Row="1" FontFamily="Consolas" AcceptsReturn="True" IsReadOnly="True"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
