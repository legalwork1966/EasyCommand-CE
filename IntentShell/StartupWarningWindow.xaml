<Window x:Class="IntentShell.StartupWarningWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Security Warning"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="500">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#D13438" Text="⚠️ Security Warning"/>
            <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" FontSize="14"
                       Text="This application is an AI-powered terminal assistant designed to execute system commands." />
            
            <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" FontSize="14" FontWeight="Medium"
                       Text="Please be aware of the following risks:" />

            <StackPanel Margin="0,10,0,10">
                <TextBlock Text="• Commands run with your full user privileges." Margin="10,2"/>
                <TextBlock Text="• AI-generated scripts can modify files, settings, or install software." Margin="10,2"/>
                <TextBlock Text="• Always review the generated commands before executing them." Margin="10,2"/>
            </StackPanel>
        </StackPanel>

        <CheckBox Grid.Row="2" x:Name="AgreeCheck"
                  Margin="0,10,0,20"
                  VerticalContentAlignment="Center"
                  Content="I understand the risks and agree to proceed."
                  Checked="AgreeCheck_Changed"
                  Unchecked="AgreeCheck_Changed"
                  FontSize="14"/>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="Exit Application" 
                    Width="120" Height="30" Margin="0,0,10,0"
                    Click="Exit_Click"/>
            
            <Button Grid.Column="2" x:Name="ContinueBtn" 
                    Content="Continue" FontWeight="Bold" IsEnabled="False"
                    Width="120" Height="30"
                    Click="Continue_Click"/>
        </Grid>
    </Grid>
</Window>